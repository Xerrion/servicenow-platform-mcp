# =============================================================================
# ServiceNow MCP Server - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# -----------------------------------------------------------------------------
# ServiceNow Connection (required)
# -----------------------------------------------------------------------------

# Instance URL - must start with https://
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com

# Authentication credentials
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your-password-here

# -----------------------------------------------------------------------------
# Server Configuration (optional)
# -----------------------------------------------------------------------------

# Tool package preset or comma-separated group names
# Presets: full, core_readonly, none, itil, developer, readonly, analyst,
#          incident_management, change_management, cmdb, problem_management,
#          request_management, knowledge_management, service_catalog
# MCP_TOOL_PACKAGE=full

# Environment label - set to "prod" or "production" to enable production guards
# SERVICENOW_ENV=dev

# Maximum rows returned per query (1-10000)
# MAX_ROW_LIMIT=100

# Comma-separated list of tables considered "large" for query safety
# LARGE_TABLE_NAMES_CSV=syslog,sys_audit,sys_log_transaction,sys_email_log

# -----------------------------------------------------------------------------
# Sentry Error Tracking (optional)
# -----------------------------------------------------------------------------

# Sentry DSN - set to enable error tracking (requires sentry-sdk)
# SENTRY_DSN=

# Sentry environment tag (defaults to SERVICENOW_ENV if not set)
# SENTRY_ENVIRONMENT=
